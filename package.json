{
  "name": "insightfeed",
  "version": "1.0.0",
  "private": true,
  "description": "InsightFeed — AI-Powered News with Sentiment Analysis",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec -- rm -rf node_modules dist .next"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "keywords": [
    "news",
    "sentiment-analysis",
    "nigeria",
    "nextjs",
    "express"
  ],
  "author": "",
  "license": "UNLICENSED"
}
