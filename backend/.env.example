# ========================
# API Keys (register at each provider)
# ========================

# NewsData.io — https://newsdata.io/register (200 credits/day free)
NEWSDATA_API_KEY=your_newsdata_api_key_here

# NewsAPI.org — https://newsapi.org/register (100 req/day free)
NEWSAPI_API_KEY=your_newsapi_api_key_here

# MediaStack — https://mediastack.com/signup/free (100 calls/month free)
MEDIASTACK_API_KEY=your_mediastack_api_key_here

# ========================
# Server Configuration
# ========================
PORT=5000
NODE_ENV=development

# ========================
# CORS — Allowed frontend origin
# ========================
CORS_ORIGIN=http://localhost:3000

# ========================
# Cache TTL (in seconds)
# ========================
RSS_CACHE_TTL=600
API_CACHE_TTL=900
